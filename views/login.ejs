<%- include('partials/head') %>
<div class="rh-page-bg" aria-hidden="true"></div>
<div class="rh-stars" aria-hidden="true"></div>

<header class="rh-top-nav rh-animate-header">
  <a href="/" class="rh-link-back">← Back to shop</a>
  <a href="/payment" class="rh-btn-ghost rh-btn-nav">Pay for access</a>
</header>

<main class="rh-auth-wrap">
  <div class="rh-auth-card rh-animate-hero">
    <div class="rh-logo" aria-hidden="true">
      <span class="rh-logo-bar"></span>
      <span class="rh-logo-bar rh-logo-bar--mid"></span>
      <span class="rh-logo-bar rh-logo-bar--short"></span>
    </div>
    <p class="rh-brand">cj.resells</p>
    <h1 class="rh-h1">Sign in</h1>
    <p class="rh-sub">Access your supplier dashboard</p>

    <% if (typeof wantedProduct !== 'undefined' && wantedProduct) { %>
      <div class="rh-callout" role="status">
        <p class="rh-callout-title">You chose: <strong><%= wantedProduct.name %></strong></p>
        <p class="rh-callout-text">To get this item you need to <strong>sign in to the dashboard</strong>. If you don’t have an account yet, purchase access first — we’ll approve you manually after payment.</p>
        <a href="/payment" class="rh-btn rh-btn-primary rh-btn-block rh-callout-btn">Purchase access</a>
      </div>
    <% } else { %>
      <div class="rh-callout rh-callout--muted" role="note">
        <p class="rh-callout-text">To request products from the shop, sign in below. <strong>No account?</strong> Purchase access and we’ll set you up.</p>
        <a href="/payment" class="rh-btn rh-btn-ghost rh-btn-block rh-callout-btn-secondary">Purchase access</a>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="rh-alert rh-alert--error" role="alert"><%= error %></div>
    <% } %>

    <form class="rh-form" method="post" action="/login" autocomplete="on">
      <% if (typeof wantedId !== 'undefined' && wantedId) { %>
        <input type="hidden" name="wanted" value="<%= wantedId %>" />
      <% } %>
      <label class="rh-label" for="username">Username</label>
      <input class="rh-input" type="text" id="username" name="username" placeholder="Enter your username" required />

      <label class="rh-label" for="password">Password</label>
      <input class="rh-input" type="password" id="password" name="password" placeholder="Enter your password" required />

      <button type="submit" class="rh-btn rh-btn-primary">Sign in</button>
    </form>

    <p class="rh-session-note">You’ll stay signed in for up to <strong>30 days</strong> (refreshed while you use the site).</p>

    <p class="rh-legal">
      <a href="/">Browse shop</a>
      <span class="rh-dot">·</span>
      <a href="/admin">Admin</a>
    </p>
  </div>
</main>

<button type="button" class="rh-fab-chat" aria-label="Support chat" title="Support">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
  </svg>
</button>

<%- include('partials/foot') %>
